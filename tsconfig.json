{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "baseUrl": "."
  },
  "include": ["src/**/*", "tools/**/*"],
  "exclude": ["node_modules"]
}
